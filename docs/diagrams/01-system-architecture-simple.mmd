graph LR
    subgraph User["👤 USER SIDE"]
        Phone["📱 Phone App<br/>(TLS encrypted)<br/>Main Wallet"]
        Watch["⌚ Smartwatch<br/>(Secure Element)<br/>NFC + BLE"]
    end
    
    subgraph Merchant["🏪 MERCHANT SIDE"]
        Terminal["🏪 NFC Terminal<br/>(ISO 14443)<br/>Payment Request"]
        MerchantBank["🏦 Merchant Bank<br/>(TLS encrypted)<br/>Settlement"]
    end
    
    subgraph Banks["🏛️ PAYMENT INFRASTRUCTURE"]
        NPCI["📡 NPCI<br/>(Batch Processor)<br/>Dedup & Route"]
        RBI["🏛️ RBI e-Rupee<br/>(CBDC Core)<br/>Immutable Ledger"]
        UserBank["🏦 User's Bank<br/>(TLS encrypted)<br/>Account Settlement"]
    end
    
    Phone -->|Phase 1: BLE + RSA/AES| Watch
    Watch -->|Phase 2: NFC + ECDSA| Terminal
    Terminal -->|Phase 3: TLS + Batch| MerchantBank
    MerchantBank -->|RSA-2048 Sig| NPCI
    NPCI -->|ECDSA Verify| RBI
    RBI -->|Settlement| UserBank
    RBI -->|Broadcast Public Keys| Terminal
    Watch -->|Phase 4: BLE Sync| Phone
    Phone -->|HTTPS Verify| RBI
    
    style User fill:#e3f2fd,stroke:#1976d2,stroke-width:3px
    style Merchant fill:#fff3e0,stroke:#d97706,stroke-width:3px
    style Banks fill:#f0f4f8,stroke:#2e7d32,stroke-width:3px
    style Watch fill:#fff8e1,stroke:#f57f17,stroke-width:2px
    style Terminal fill:#fce4ec,stroke:#c2185b,stroke-width:2px
    style RBI fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px

